OPENAI_API_KEY=replace-with-render-secret

# Recommended for stable signed classifier handoffs across workers and key rotations.
FACTGPT_CLASSIFICATION_SIGNING_KEY=replace-with-random-server-secret

# Set after the Chrome Web Store assigns a stable extension ID.
FACTGPT_REQUIRE_ALLOWED_ORIGIN=true
FACTGPT_ALLOWED_ORIGIN_REGEX=^chrome-extension://your-extension-id$

# Optional private-beta token. Do not embed this in a public extension build.
# FACTGPT_PUBLIC_API_TOKEN=replace-with-random-server-secret

FACTGPT_RATE_LIMIT_PER_MINUTE=30
FACTGPT_MAX_REQUEST_BODY_BYTES=200000
FACTGPT_MAX_REQUEST_TEXT_CHARS=50000
FACTGPT_MAX_FETCH_BYTES=1000000
FACTGPT_MAX_EXTRACTED_TEXT_CHARS=12000
FACTGPT_FACT_OPINION_API_MODEL=gpt-5.6-luna
FACTGPT_FACT_OPINION_REASONING_EFFORT=none
FACTGPT_OPENAI_BIAS_TIMEOUT_SECONDS=60
FACTGPT_OPENAI_RESEARCH_TIMEOUT_SECONDS=120
FACTGPT_OPENAI_BACKGROUND_RESEARCH_TIMEOUT_SECONDS=300

# Podcast mode keeps these caps separate from the small JSON/article limits.
FACTGPT_MAX_PODCAST_AUDIO_BYTES=200000000
FACTGPT_MAX_PODCAST_DURATION_SECONDS=10800
FACTGPT_MAX_PODCAST_TRANSCRIPT_BYTES=5000000
FACTGPT_MAX_PODCAST_PAGE_BYTES=2000000
FACTGPT_PODCAST_JOB_TTL_SECONDS=86400
